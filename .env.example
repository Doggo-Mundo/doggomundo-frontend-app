# ==============================================================================
# Doggo Mundo App — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in the values for local dev.
# In Vercel, set each variable per scope (Production, Preview, Development).
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------
# Local dev: "/api" works because Vite proxies it to localhost:8000.
# Vercel prod: https://api.doggomundo.com.mx/api
# Vercel staging: https://staging-api.doggomundo.com.mx/api
VITE_API_BASE_URL=/api

# ------------------------------------------------------------------------------
# Stripe — publishable key
# ------------------------------------------------------------------------------
# Safe to ship to the client (it only authorizes tokenization). The
# matching secret key lives in the backend env. Use the test key
# (pk_test_...) for local + staging, live key (pk_live_...) for prod.
# Without this, the Stripe Elements provider stays disabled and the
# "Mis métodos de pago" page renders an empty state.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------------------------
# Sentry (opt-in, leave empty for local dev)
# ------------------------------------------------------------------------------
# When VITE_SENTRY_DSN is empty, Sentry stays dormant (no init, no
# network calls). Set it in Vercel for staging and production.
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# Server-side build env vars (NO VITE_ prefix; never shipped to the
# client). Set them only in Vercel build env, never in .env.local.
# When SENTRY_AUTH_TOKEN is missing, the Vite plugin no-ops and source
# maps are not uploaded.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=doggomundo
# SENTRY_PROJECT=doggomundo-cliente
